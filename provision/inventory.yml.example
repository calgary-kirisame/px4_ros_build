all:
  vars:
    # Cloud-init provisioning vars (used by flash.yml on localhost)
    wifi_ssid: NameOfNetwork
    wifi_password: password
    maav_password_hash: ""
    ssh_authorized_keys: [""]
    # Reusable, tagged pre-auth key from https://login.tailscale.com/admin/settings/keys
    # Leave empty to skip Tailscale authentication at flash time.
    tailscale_authkey: ""
  children:
    drones:
      hosts:
        bigpi5:
        drone0:
        drone1:
        drone2:
        drone3:
        drone4:
      vars:
        ansible_user: maav
        # Tailscale MagicDNS resolves hostnames automatically.
        # If not enabled, add per-host ansible_host overrides.
